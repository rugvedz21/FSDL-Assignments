<%- include('partials/header') %>

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">Find Your <span class="gradient">Dream Ride</span></h1>
    <p class="hero-sub">India's premium marketplace for certified pre-owned cars 🚀</p>
    <form action="/" method="GET" class="search-bar">
      <input type="text" name="search" placeholder="Search by brand or model..." value="<%= query.search || '' %>">
      <button type="submit">🔍 Search</button>
    </form>
  </div>
  <div class="hero-blob"></div>
</section>

<% if (featured.length) { %>
<section class="section">
  <h2 class="section-title">⭐ Featured Deals</h2>
  <div class="grid">
    <% featured.forEach(car => { %>
      <a href="/cars/<%= car._id %>" class="card featured">
        <div class="card-img" style="background-image:url('<%= car.image %>')">
          <span class="featured-badge">FEATURED</span>
        </div>
        <div class="card-body">
          <h3><%= car.brand %> <%= car.model %></h3>
          <p class="price">₹<%= car.price.toLocaleString('en-IN') %></p>
          <p class="meta"><%= car.year %> · <%= car.kmDriven.toLocaleString() %> km · <%= car.fuel %></p>
        </div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<section class="section">
  <div class="section-head">
    <h2 class="section-title">🚗 All Cars (<%= cars.length %>)</h2>
    <form method="GET" class="filters">
      <select name="brand" onchange="this.form.submit()">
        <option value="">All Brands</option>
        <% brands.forEach(b => { %>
          <option value="<%= b %>" <%= query.brand===b?'selected':'' %>><%= b %></option>
        <% }) %>
      </select>
      <select name="fuel" onchange="this.form.submit()">
        <option value="">All Fuels</option>
        <% ['Petrol','Diesel','Electric','Hybrid','CNG'].forEach(f => { %>
          <option value="<%= f %>" <%= query.fuel===f?'selected':'' %>><%= f %></option>
        <% }) %>
      </select>
      <select name="sort" onchange="this.form.submit()">
        <option value="">Sort: Latest</option>
        <option value="low" <%= query.sort==='low'?'selected':'' %>>Price: Low → High</option>
        <option value="high" <%= query.sort==='high'?'selected':'' %>>Price: High → Low</option>
        <option value="new" <%= query.sort==='new'?'selected':'' %>>Year: Newest</option>
      </select>
    </form>
  </div>

  <% if (!cars.length) { %>
    <div class="empty">😔 No cars found. <a href="/cars/new">Be the first to list one!</a></div>
  <% } %>

  <div class="grid">
    <% cars.forEach(car => { %>
      <a href="/cars/<%= car._id %>" class="card">
        <div class="card-img" style="background-image:url('<%= car.image %>')"></div>
        <div class="card-body">
          <h3><%= car.brand %> <%= car.model %></h3>
          <p class="price">₹<%= car.price.toLocaleString('en-IN') %></p>
          <p class="meta"><%= car.year %> · <%= car.kmDriven.toLocaleString() %> km · <%= car.fuel %></p>
          <div class="tags">
            <span class="tag"><%= car.transmission %></span>
            <span class="tag">📍 <%= car.location %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
